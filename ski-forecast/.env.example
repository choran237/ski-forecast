# These are set automatically when you connect Vercel KV in the Vercel dashboard.
# Do NOT put real values here — add them in Vercel → Project → Settings → Environment Variables

KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# SerpApi — get key from serpapi.com
SERP_API_KEY=your_serpapi_key_here
