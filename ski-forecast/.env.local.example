# Copy this file to .env.local and fill in your values for local development

# Upstash Redis (get from upstash.com or Vercel Storage dashboard)
KV_REST_API_URL=https://your-redis-url.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here

# SerpApi (get from serpapi.com)
SERP_API_KEY=your_serpapi_key_here

# Anthropic (get from console.anthropic.com) — for AI Resort Intelligence feature
ANTHROPIC_API_KEY=your_anthropic_key_here
